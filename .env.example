# SumoSpace Configuration
# Copy this file to .env and fill in your values

# Provider (hf | ollama | vllm | gemini | openai | anthropic)
SUMO_PROVIDER=ollama
SUMO_MODEL=phi3:mini

# Ollama server (if using Ollama)
SUMO_OLLAMA_BASE_URL=http://localhost:11434

# vLLM server (if using vLLM)
SUMO_VLLM_BASE_URL=http://localhost:8000

# Cloud API keys (only needed if using cloud providers)
# GOOGLE_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# Pipeline toggles
SUMO_COMMITTEE_ENABLED=true
SUMO_RAG_ENABLED=true
SUMO_MEMORY_ENABLED=true

# Shell safety
SUMO_SHELL_SANDBOX=false

# Observability
SUMO_AUDIT_LOG_ENABLED=true
SUMO_TELEMETRY_ENABLED=false
