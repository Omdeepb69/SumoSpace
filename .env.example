# SUMOSPACE ENVIRONMENT CONFIGURATION
# =====================================
# NOTHING HERE IS REQUIRED FOR THE DEFAULT SETUP.
# The default local stack (HuggingFace + local embeddings) needs zero API keys.
#
# Only set the keys for providers you explicitly want to use.


# ── OPTIONAL: Google Gemini + Embeddings ──────────────────────────────────────
# Required only if you set: provider="gemini" or embedding_provider="google"
# Get free key: https://aistudio.google.com/apikey (generous free tier)
# GOOGLE_API_KEY=your_key_here


# ── OPTIONAL: OpenAI ──────────────────────────────────────────────────────────
# Required only if you set: provider="openai"
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_key_here


# ── OPTIONAL: Anthropic Claude ────────────────────────────────────────────────
# Required only if you set: provider="anthropic"
# https://console.anthropic.com
# ANTHROPIC_API_KEY=your_key_here


# ── OPTIONAL: Override defaults ───────────────────────────────────────────────
# SUMO_DEFAULT_PROVIDER=ollama        # Switch default to Ollama
# SUMO_DEFAULT_MODEL=phi3:mini        # Ollama model
# SUMO_HF_LOAD_IN_4BIT=true          # Reduce VRAM usage for HF models
# SUMO_CHROMA_PATH=.my_custom_db     # Custom ChromaDB path
